# ==============================
# JVM Diagnostics Analyzer
# ==============================
# Copy this file to .env and fill in your values.
# Docker Compose and the application will read these.

# Required — Your OpenRouter API key
OPENROUTER_API_KEY=sk-or-your-key-here

# AI Configuration (optional)
# OPENROUTER_BASE_URL=https://openrouter.ai/api
# AI_MODEL=openai/gpt-4o
# AI_TEMPERATURE=0.3

# Upload Limits (optional)
# MAX_FILE_SIZE=5GB
# MAX_REQUEST_SIZE=5GB
# FILE_SIZE_THRESHOLD=10MB

# JVM tuning (optional, Docker only)
# JAVA_OPTS=-Xms512m -Xmx2g

# Server port (optional)
# SERVER_PORT=8080

# MAT configuration for heap dump analysis (optional)
# APP_MAT_TIMEOUT_MINUTES=30
# MAT_HEAP_SIZE=4g
